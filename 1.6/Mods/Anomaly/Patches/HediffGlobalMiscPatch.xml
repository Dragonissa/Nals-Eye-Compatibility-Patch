<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Anomaly</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>*/HediffDef[defName="VoidTouched"]//texPath</xpath>
					<value>
						<texPath>Things/None</texPath>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>*/HediffDef[defName="VoidTouched"]//texPathFemale</xpath>
					<value>
						<texPathFemale>Things/None</texPathFemale>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>